import json
import os.path

top = '.'
out = 'build'


def package_watchface_mode():
    package_path = os.path.join(top, 'package.json')
    if not os.path.exists(package_path):
        return False
    try:
        with open(package_path, 'r', encoding='utf-8') as handle:
            package = json.load(handle)
    except (OSError, ValueError):
        return False
    return package.get('pebble', {}).get('watchapp', {}).get('watchface') is True


def options(ctx):
    ctx.load('pebble_sdk')


def configure(ctx):
    """
    This method is used to configure your build. ctx.load(`pebble_sdk`) automatically configures
    a build for each valid platform in `targetPlatforms`. Platform-specific configuration: add your
    change after calling ctx.load('pebble_sdk') and make sure to set the correct environment first.
    Universal configuration: add your change prior to calling ctx.load('pebble_sdk').
    """
    ctx.load('pebble_sdk')
    for env in ctx.all_envs.values():
        env.append_value('CFLAGS', ['-ffunction-sections', '-fdata-sections'])
        env.append_value('LINKFLAGS', ['-Wl,--gc-sections'])
    if os.environ.get('ELMC_PEBBLE_TRACE_FUNCTIONS') in ('1', 'true', 'TRUE', 'yes', 'YES'):
        for env in ctx.all_envs.values():
            env.append_value('CFLAGS', ['-DELMC_PEBBLE_TRACE_FUNCTIONS=1'])
    if os.environ.get('ELMC_PEBBLE_HEAP_LOG') in ('1', 'true', 'TRUE', 'yes', 'YES'):
        for env in ctx.all_envs.values():
            env.append_value('CFLAGS', ['-DELMC_PEBBLE_HEAP_LOG=1'])
    if os.environ.get('ELMC_ALLOC_TRACE') in ('1', 'true', 'TRUE', 'yes', 'YES'):
        for env in ctx.all_envs.values():
            env.append_value('CFLAGS', ['-DELMC_ALLOC_TRACE=1'])
    if os.environ.get('ELMC_PEBBLE_EMULATOR_STORAGE_LOGS') in ('1', 'true', 'TRUE', 'yes', 'YES'):
        for env in ctx.all_envs.values():
            env.append_value('CFLAGS', ['-DELMC_PEBBLE_EMULATOR_STORAGE_LOGS=1'])
    if os.environ.get('ELMC_PEBBLE_RUNTIME_LOGS') in ('1', 'true', 'TRUE', 'yes', 'YES'):
        for env in ctx.all_envs.values():
            env.append_value('CFLAGS', ['-DELMC_PEBBLE_RUNTIME_LOGS=1'])
    # ELMC_AGENT_PROBES is controlled by src/c/elmc_emulator_build_flags.h (IDE-generated).
    # Do not read ELMC_AGENT_PROBES from the shell here — a leaked env var must not override it.
    init_stage = os.environ.get('ELMC_AGENT_PROBE_INIT_STAGE')
    if init_stage:
        for env in ctx.all_envs.values():
            env.append_value('CFLAGS', ['-DELMC_AGENT_PROBE_INIT_STAGE={}'.format(init_stage)])
    watchface_mode = os.environ.get('ELMC_WATCHFACE_MODE') in ('1', 'true', 'TRUE', 'yes', 'YES')
    if not watchface_mode:
        watchface_mode = package_watchface_mode()
    if watchface_mode:
        for env in ctx.all_envs.values():
            env.append_value('CFLAGS', ['-DELMC_WATCHFACE_MODE=1'])

def build(ctx):
    ctx.load('pebble_sdk')

    build_worker = os.path.exists('worker_src')
    binaries = []

    cached_env = ctx.env
    for platform in ctx.env.TARGET_PLATFORMS:
        ctx.env = ctx.all_envs[platform]
        ctx.set_group(ctx.env.PLATFORM_NAME)
        app_elf = '{}/pebble-app.elf'.format(ctx.env.BUILD_DIR)
        app_map = '{}/pebble-app.map'.format(ctx.env.BUILD_DIR)
        ctx.env.append_value('LINKFLAGS', ['-Wl,-Map,{}'.format(app_map)])
        ctx.pbl_build(
            source=ctx.path.ant_glob(
                'src/c/**/*.c',
                excl=['src/c/elmc/c/host_harness.c']
            ),
            target=app_elf,
            bin_type='app'
        )

        if build_worker:
            worker_elf = '{}/pebble-worker.elf'.format(ctx.env.BUILD_DIR)
            binaries.append({'platform': platform, 'app_elf': app_elf, 'worker_elf': worker_elf})
            ctx.pbl_build(source=ctx.path.ant_glob('worker_src/c/**/*.c'),
                          target=worker_elf,
                          bin_type='worker')
        else:
            binaries.append({'platform': platform, 'app_elf': app_elf})
    ctx.env = cached_env

    ctx.set_group('bundle')
    bundle_args = {'binaries': binaries}
    if os.path.exists('src/pkjs/index.js'):
        bundle_args['js'] = ctx.path.ant_glob([
            'src/pkjs/**/*.js',
            'src/pkjs/**/*.json',
            'src/common/**/*.js'
        ])
        bundle_args['js_entry_file'] = 'src/pkjs/index.js'
    ctx.pbl_bundle(**bundle_args)
