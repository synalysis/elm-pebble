diff --git a/hw/arm/pebble.c b/hw/arm/pebble.c
--- a/hw/arm/pebble.c
+++ b/hw/arm/pebble.c
@@ -73,4 +73,99 @@
  * Board configurations
  * ==================================================================== */
 
+#define SDK_RTC_TIME_SCALE 64
+#define SDK_RTC_ALARM_ENABLE 1
+
+static MemoryRegion s_sdk_rtc_iomem;
+static QEMUTimer *s_sdk_rtc_alarm_timer;
+static qemu_irq s_sdk_rtc_alarm_irq;
+static int64_t s_sdk_rtc_epoch_ms;
+static uint32_t s_sdk_rtc_alarm_ms;
+static uint32_t s_sdk_rtc_control;
+
+static uint32_t sdk_rtc_elapsed_ms(void)
+{
+    int64_t elapsed = qemu_clock_get_ms(QEMU_CLOCK_VIRTUAL) - s_sdk_rtc_epoch_ms;
+    return elapsed < 0 ? 0 : (uint32_t)(elapsed / SDK_RTC_TIME_SCALE);
+}
+
+static void sdk_rtc_update_alarm(void)
+{
+    uint32_t now_ms;
+    uint32_t delay_ms;
+    int64_t deadline_ms;
+
+    if (!s_sdk_rtc_alarm_timer) {
+        return;
+    }
+
+    if (!(s_sdk_rtc_control & SDK_RTC_ALARM_ENABLE)) {
+        timer_del(s_sdk_rtc_alarm_timer);
+        return;
+    }
+
+    now_ms = sdk_rtc_elapsed_ms();
+    delay_ms = s_sdk_rtc_alarm_ms > now_ms ? s_sdk_rtc_alarm_ms - now_ms : 0;
+    deadline_ms = qemu_clock_get_ms(QEMU_CLOCK_VIRTUAL) +
+                  (int64_t)delay_ms * SDK_RTC_TIME_SCALE;
+    timer_mod(s_sdk_rtc_alarm_timer, deadline_ms);
+}
+
+static void sdk_rtc_alarm_cb(void *opaque)
+{
+    s_sdk_rtc_control &= ~SDK_RTC_ALARM_ENABLE;
+    qemu_irq_pulse(s_sdk_rtc_alarm_irq);
+}
+
+static uint64_t sdk_rtc_read(void *opaque, hwaddr offset, unsigned size)
+{
+    switch (offset) {
+    case 0x00:
+        return sdk_rtc_elapsed_ms() / 1000;
+    case 0x08:
+        return s_sdk_rtc_alarm_ms;
+    case 0x0c:
+        return s_sdk_rtc_control;
+    case 0x10:
+        return sdk_rtc_elapsed_ms();
+    default:
+        return 0;
+    }
+}
+
+static void sdk_rtc_write(void *opaque, hwaddr offset, uint64_t value,
+                          unsigned size)
+{
+    switch (offset) {
+    case 0x08:
+        s_sdk_rtc_alarm_ms = (uint32_t)value;
+        sdk_rtc_update_alarm();
+        break;
+    case 0x0c:
+        s_sdk_rtc_control = (uint32_t)value;
+        sdk_rtc_update_alarm();
+        break;
+    default:
+        break;
+    }
+}
+
+static const MemoryRegionOps sdk_rtc_ops = {
+    .read = sdk_rtc_read,
+    .write = sdk_rtc_write,
+    .endianness = DEVICE_NATIVE_ENDIAN,
+};
+
+static void pebble_init_sdk_rtc(qemu_irq alarm_irq)
+{
+    s_sdk_rtc_alarm_irq = alarm_irq;
+    s_sdk_rtc_epoch_ms = qemu_clock_get_ms(QEMU_CLOCK_VIRTUAL);
+    s_sdk_rtc_alarm_timer = timer_new_ms(QEMU_CLOCK_VIRTUAL,
+                                         sdk_rtc_alarm_cb, NULL);
+    memory_region_init_io(&s_sdk_rtc_iomem, NULL, &sdk_rtc_ops, NULL,
+                          "pebble-sdk-rtc", 0x100);
+    memory_region_add_subregion(get_system_memory(), 0x40005000,
+                                &s_sdk_rtc_iomem);
+}
+
