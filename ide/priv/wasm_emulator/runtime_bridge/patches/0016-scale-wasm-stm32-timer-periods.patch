diff --git a/hw/timer/stm32_pebble_tim.c b/hw/timer/stm32_pebble_tim.c
index ce6ddaf..6235b12 100644
--- a/hw/timer/stm32_pebble_tim.c
+++ b/hw/timer/stm32_pebble_tim.c
@@ -66,6 +66,13 @@
 #define R_TIM_OR     (0x50 / 4)
 #define R_TIM_MAX    (0x54 / 4)
 
+/*
+ * The browser/TCI runtime advances guest work much more slowly than the real
+ * MCU. Keep watchdog-style general-purpose timers from firing before the
+ * emulated firmware has had a fair chance to schedule lower-priority tasks.
+ */
+#define STM32_TIM_WASM_PERIOD_SCALE 4096
+
 static const char *f2xx_tim_reg_names[] = {
     ENUM_STRING(R_TIM_CR1),
     ENUM_STRING(R_TIM_CR2),
@@ -115,7 +122,9 @@ f2xx_tim_next_transition(f2xx_tim *s, int64_t current_time)
         qemu_log_mask(LOG_UNIMP, "f2xx tim, only upedge-aligned mode supported\n");
         return -1;
     }
-    return current_time + f2xx_tim_period(s) * s->regs[R_TIM_ARR];
+    return current_time +
+           f2xx_tim_period(s) * s->regs[R_TIM_ARR] *
+               STM32_TIM_WASM_PERIOD_SCALE;
 }
 
 static void
