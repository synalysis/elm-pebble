 #define DPRINTF(fmt, ...)                                 \
@@ -191,6 +196,85 @@
     uint32_t send_char_bytes;    /* number of bytes avaialable in send_char_buf */
 };
 
+
+#ifdef __EMSCRIPTEN__
+#define PEBBLE_WASM_CONTROL_QUEUE_LEN 32
+
+static PebbleControl *s_wasm_control;
+static uint8_t s_wasm_control_queue[PEBBLE_WASM_CONTROL_QUEUE_LEN][PBLCONTROL_BUF_LEN];
+static uint32_t s_wasm_control_queue_len[PEBBLE_WASM_CONTROL_QUEUE_LEN];
+static uint32_t s_wasm_control_queue_read;
+static uint32_t s_wasm_control_queue_write;
+static int pebble_control_can_receive(void *opaque);
+static void pebble_control_receive(void *opaque, const uint8_t *buf, int size);
+
+static void pebble_control_wasm_queue_packet(const uint8_t *data, uint32_t len)
+{
+    uint32_t next = (s_wasm_control_queue_write + 1) % PEBBLE_WASM_CONTROL_QUEUE_LEN;
+
+    if (len > PBLCONTROL_BUF_LEN) {
+        return;
+    }
+
+    if (next == s_wasm_control_queue_read) {
+        /* Drop the oldest packet rather than blocking QEMU. */
+        s_wasm_control_queue_read =
+            (s_wasm_control_queue_read + 1) % PEBBLE_WASM_CONTROL_QUEUE_LEN;
+    }
+
+    memcpy(s_wasm_control_queue[s_wasm_control_queue_write], data, len);
+    s_wasm_control_queue_len[s_wasm_control_queue_write] = len;
+    s_wasm_control_queue_write = next;
+}
+
+EMSCRIPTEN_KEEPALIVE int pebble_control_wasm_send(uint8_t *data, int len)
+{
+    bool already_locked;
+
+    if (!s_wasm_control || !data || len <= 0) {
+        return 0;
+    }
+
+    already_locked = bql_locked();
+    if (!already_locked) {
+        bql_lock();
+    }
+
+    if (len > pebble_control_can_receive(s_wasm_control)) {
+        if (!already_locked) {
+            bql_unlock();
+        }
+        return 0;
+    }
+
+    pebble_control_receive(s_wasm_control, data, len);
+
+    if (!already_locked) {
+        bql_unlock();
+    }
+
+    return len;
+}
+
+EMSCRIPTEN_KEEPALIVE int pebble_control_wasm_recv(uint8_t *out, int capacity)
+{
+    uint32_t len;
+
+    if (!out || capacity <= 0 || s_wasm_control_queue_read == s_wasm_control_queue_write) {
+        return 0;
+    }
+
+    len = s_wasm_control_queue_len[s_wasm_control_queue_read];
+    if ((uint32_t)capacity < len) {
+        return -((int)len);
+    }
+
+    memcpy(out, s_wasm_control_queue[s_wasm_control_queue_read], len);
+    s_wasm_control_queue_read =
+        (s_wasm_control_queue_read + 1) % PEBBLE_WASM_CONTROL_QUEUE_LEN;
+    return (int)len;
+}
+#endif
 
