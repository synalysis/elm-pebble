diff --git a/hw/misc/pebble_null_i2c.c b/hw/misc/pebble_null_i2c.c
--- a/hw/misc/pebble_null_i2c.c
+++ b/hw/misc/pebble_null_i2c.c
@@ -84,5 +84,6 @@ static void pebble_null_i2c_reset(DeviceState *dev)
 {
     PebbleNullI2C *pmic = PEBBLE_NULL_I2C(dev);
+    I2CSlave *slave = I2C_SLAVE(dev);
 
     memset(pmic->regs, 0, sizeof(pmic->regs));
     pmic->pointer = 0;
@@ -92,6 +93,12 @@ static void pebble_null_i2c_reset(DeviceState *dev)
 
     pmic->regs[0x90] = 0x11; /* AS3701B chip ID */
     pmic->regs[0x91] = 0x01; /* benign revision */
+    if (slave->address == 0x28) {
+        pmic->regs[0x00] = 0x01; /* MAX14690 PMIC WHOAMI */
+        pmic->regs[0x08] = 0x01; /* MAX14690 PMIC WHOAMI */
+    } else if (slave->address == 0x0e) {
+        pmic->regs[0x07] = 0xc4; /* MAG3110 WHOAMI */
+    }
 }
 
