+static void pebble_init_pmic_mag_i2c(struct stm32f4xx *stm)
+{
+    I2CBus *bus;
+
+    if (!stm->i2c_dev[0]) {
+        return;
+    }
+
+    bus = I2C_BUS(qdev_get_child_bus(stm->i2c_dev[0], "i2c"));
+    i2c_slave_create_simple(bus, "pebble-null-i2c", 0x28);
+    i2c_slave_create_simple(bus, "pebble-null-i2c", 0x0e);
+}
