         break;
     }
     case R_DR:
@@ -266,6 +294,7 @@ stm32f412_qspi_write(void *arg, hwaddr addr, uint64_t data, unsigned size)
         DB_PRINT_L(2, "Write %u of %" PRIi64 " remaining",
                     size, s->tx_remaining);
         s->regs[R_DR] = 0;
+        stm32f412_qspi_start_transaction(s);
         stm32f412_qspi_xfer(s, data, size);
         s->tx_remaining -= size;
         break;
@@ -287,6 +316,7 @@ stm32f412_qspi_write(void *arg, hwaddr addr, uint64_t data, unsigned size)
 
     if (s->tx_remaining <= 0) {
         stm32f412_set_cs(s, CS_STATE_HIGH);
+        s->transaction_started = false;
     }
 
     s->regs[R_SR] |= R_SR_TCF;
@@ -302,6 +332,7 @@ stm32f412_qspi_reset(DeviceState *dev)
     memset(s->regs, 0, sizeof(s->regs));
     s->cs_state = CS_STATE_HIGH;
     s->tx_remaining = 0;
+    s->transaction_started = false;
     s->trace_reads = 0;
 }
 
