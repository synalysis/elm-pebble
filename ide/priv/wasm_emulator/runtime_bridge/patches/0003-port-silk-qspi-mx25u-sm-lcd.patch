+
+    /* === Display (SM-LCD on SPI2) === */
+    spi = (SSIBus *)qdev_get_child_bus(stm.spi_dev[1], "ssi");
+    DeviceState *display_dev = qdev_new("sm-lcd");
+    qdev_prop_set_bit(display_dev, "rotate_display", false);
