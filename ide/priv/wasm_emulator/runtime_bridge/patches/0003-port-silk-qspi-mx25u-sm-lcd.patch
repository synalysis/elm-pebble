 {
-    /* F412 SoC init - reuse F4xx for now (same peripherals, different memory) */
-    pebble_32f439_init(machine, board_config);
+    Stm32Gpio *gpio[STM32F4XX_GPIO_COUNT];
+    Stm32Uart *uart[STM32F4XX_UART_COUNT];
