+                                                     SSI_GPIO_CS, 0);
+        qdev_connect_gpio_out_named(stm.qspi_dev, "qspi-gpio-cs", 0,
+                                    flash_cs);
+        /* QSPI memory-mapped mode exposes external flash at 0x90000000. */
+        memory_region_add_subregion(get_system_memory(), 0x90000000,
+                                    mx25u_get_mmap(flash_dev));
