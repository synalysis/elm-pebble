+    DeviceState *rtc_dev;
+    SSIBus *spi;
+    struct stm32f4xx stm;
+    ARMCPU *cpu;
+
+    stm32f4xx_init(board_config->flash_size,
+                   board_config->ram_size,
+                   machine->kernel_filename,
+                   gpio,
+                   board_config->gpio_idr_masks,
+                   uart,
+                   timer,
+                   &rtc_dev,
