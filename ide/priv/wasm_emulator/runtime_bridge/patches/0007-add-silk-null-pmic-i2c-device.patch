diff --git a/hw/misc/pebble_null_i2c.c b/hw/misc/pebble_null_i2c.c
new file mode 100644
index 0000000..86a9d6a
--- /dev/null
+++ b/hw/misc/pebble_null_i2c.c
@@ -0,0 +1,119 @@
+/*
+ * Pebble Null I2C Device
+ *
+ * Minimal AS3701B-like I2C slave used by Silk/Diorite firmware. It models a
+ * register pointer plus enough defaults for the PMIC driver to identify the
+ * chip and report early transactions while Diorite support is still being
+ * brought up.
+ *
+ * Copyright (c) 2026 Core Devices LLC
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#include "qemu/osdep.h"
+#include "hw/i2c/i2c.h"
+#include "qom/object.h"
+
+#define TYPE_PEBBLE_NULL_I2C "pebble-null-i2c"
+OBJECT_DECLARE_SIMPLE_TYPE(PebbleNullI2C, PEBBLE_NULL_I2C)
+
+struct PebbleNullI2C {
+    I2CSlave parent_obj;
+
+    uint8_t regs[256];
+    uint8_t pointer;
+    bool expecting_register;
+};
+
+static bool pebble_null_i2c_match_and_add(I2CSlave *candidate,
+                                          uint8_t address,
+                                          bool broadcast,
+                                          I2CNodeList *current_devs)
+{
+    if (!broadcast && address != candidate->address) {
+        return false;
+    }
+
+    I2CNode *node = g_new(struct I2CNode, 1);
+
+    node->elt = candidate;
+    QLIST_INSERT_HEAD(current_devs, node, next);
+    return true;
+}
+
+static int pebble_null_i2c_event(I2CSlave *s, enum i2c_event event)
+{
+    PebbleNullI2C *pmic = PEBBLE_NULL_I2C(s);
+
+    if (event == I2C_START_SEND) {
+        pmic->expecting_register = true;
+    }
+
+    return 0;
+}
+
+static int pebble_null_i2c_send(I2CSlave *s, uint8_t data)
+{
+    PebbleNullI2C *pmic = PEBBLE_NULL_I2C(s);
+
+    if (pmic->expecting_register) {
+        pmic->pointer = data;
+        pmic->expecting_register = false;
+        fprintf(stderr, "PEBBLE_AS3701B reg=0x%02x\n", data);
+    } else {
+        fprintf(stderr, "PEBBLE_AS3701B write reg=0x%02x val=0x%02x\n",
+                pmic->pointer, data);
+        pmic->regs[pmic->pointer++] = data;
+    }
+
+    return 0;
+}
+
+static uint8_t pebble_null_i2c_recv(I2CSlave *s)
+{
+    PebbleNullI2C *pmic = PEBBLE_NULL_I2C(s);
+
+    uint8_t value = pmic->regs[pmic->pointer++];
+
+    fprintf(stderr, "PEBBLE_AS3701B read reg=0x%02x val=0x%02x\n",
+            (uint8_t)(pmic->pointer - 1), value);
+    return value;
+}
+
+static void pebble_null_i2c_reset(DeviceState *dev)
+{
+    PebbleNullI2C *pmic = PEBBLE_NULL_I2C(dev);
+
+    memset(pmic->regs, 0, sizeof(pmic->regs));
+    pmic->pointer = 0;
+    pmic->expecting_register = true;
+
+    pmic->regs[0x90] = 0x11; /* AS3701B chip ID */
+    pmic->regs[0x91] = 0x01; /* benign revision */
+}
+
+static void pebble_null_i2c_class_init(ObjectClass *klass, const void *data)
+{
+    I2CSlaveClass *sc = I2C_SLAVE_CLASS(klass);
+    DeviceClass *dc = DEVICE_CLASS(klass);
+
+    device_class_set_legacy_reset(dc, pebble_null_i2c_reset);
+    sc->match_and_add = pebble_null_i2c_match_and_add;
+    sc->event = pebble_null_i2c_event;
+    sc->send = pebble_null_i2c_send;
+    sc->recv = pebble_null_i2c_recv;
+}
+
+static const TypeInfo pebble_null_i2c_info = {
+    .name          = TYPE_PEBBLE_NULL_I2C,
+    .parent        = TYPE_I2C_SLAVE,
+    .instance_size = sizeof(PebbleNullI2C),
+    .class_init    = pebble_null_i2c_class_init,
+};
+
+static void pebble_null_i2c_register_types(void)
+{
+    type_register_static(&pebble_null_i2c_info);
+}
+
+type_init(pebble_null_i2c_register_types)
