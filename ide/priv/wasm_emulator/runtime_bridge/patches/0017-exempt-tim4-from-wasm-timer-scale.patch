     MemoryRegion iomem;
     QEMUTimer *timer;
     qemu_irq irq;
+    stm32_periph_t periph;
+    uint32_t period_scale;
     uint32_t regs[R_TIM_MAX];
 
     qemu_irq pwm_ratio_changed;
@@ -115,6 +117,16 @@ f2xx_tim_period(f2xx_tim *s)
     return 31250;
 }
 
+static uint32_t
+f2xx_tim_period_scale(f2xx_tim *s)
+{
+    /*
+     * TIM4 drives firmware button debounce. Scaling it makes ordinary clicks
+     * take minutes to settle, so keep it at guest firmware timing.
+     */
+    return s->periph == STM32_TIM4 ? 1 : s->period_scale;
+}
+
 static int64_t
 f2xx_tim_next_transition(f2xx_tim *s, int64_t current_time)
 {
@@ -126,7 +138,7 @@ f2xx_tim_next_transition(f2xx_tim *s, int64_t current_time)
     }
     return current_time +
            f2xx_tim_period(s) * s->regs[R_TIM_ARR] *
-               STM32_TIM_WASM_PERIOD_SCALE;
+               f2xx_tim_period_scale(s);
 }
 
