+static uint32_t
+f2xx_tim_period_scale(f2xx_tim *s)
+{
+    /*
+     * TIM4 drives firmware button debounce. Scaling it makes ordinary clicks
+     * take minutes to settle, so keep it at guest firmware timing.
+     */
+    return s->periph == STM32_TIM4 ? 1 : STM32_TIM_WASM_PERIOD_SCALE;
+}
