diff --git a/patches/armv7m_nvic_v7m_enable_writes.patch b/patches/armv7m_nvic_v7m_enable_writes.patch
new file mode 100644
--- /dev/null
+++ b/patches/armv7m_nvic_v7m_enable_writes.patch
@@ -0,0 +1,82 @@
