{
    "type": "package",
    "name": "elm-community/elm-pebble",
    "summary": "Build Pebble smartwatch applications in Elm",
    "license": "MIT",
    "version": "2.0.0",
    "exposed-modules": [
        "Pebble",
        "Pebble.Canvas",
        "Pebble.Events",
        "Pebble.Time",
        "Pebble.Navigation",
        "Pebble.Storage",
        "Pebble.Http",
        "Pebble.WebSocket",
        "Pebble.Hardware"
    ],
    "elm-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "elm/core": "1.0.0 <= v < 2.0.0",
        "elm/json": "1.0.0 <= v < 2.0.0",
        "elm/time": "1.0.0 <= v < 2.0.0"
    },
    "test-dependencies": {}
} 